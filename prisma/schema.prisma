generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String
  slug      String    @unique
  image     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  products  Product[]
}

model Product {
  id             Int      @id @default(autoincrement())
  categoryId     Int
  name           String
  slug           String   @unique
  description    String?
  price          Float
  discount_price Float?
  stock          Int      @default(0)
  image          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  category   Category         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  carts      Cart[]
  messages   Message[]
  orderItems OrderItem[]
  variants   ProductVariant[]
  reviews    Review[]
}

model ProductVariant {
  id               Int      @id @default(autoincrement())
  productId        Int
  name             String
  additional_price Float    @default(0)
  stock            Int      @default(0)
  image            String?
  price            Float?   @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now())

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  carts      Cart[]
  orderItems OrderItem[]
}

model User {
  id              String   @id // Menggunakan String untuk UUID Supabase Auth
  name            String?
  email           String   @unique
  password        String?
  role            String   @default("customer")
  phone_number    String?
  address         String?
  points          Int      @default(0)
  membership_tier String   @default("bronze")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  carts    Cart[]
  messages Message[]
  orders   Order[]
  reviews  Review[]
}

model Review {
  id        Int      @id @default(autoincrement())
  userId    String
  productId Int
  orderId     Int
  rating    Int      @default(5)
  comment   String?
  image       String?
  admin_reply String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Cart {
  id          Int      @id @default(autoincrement())
  userId      String
  productId   Int
  variantId   Int?
  variantName String?
  price       Int
  quantity    Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Order {
  id Int @id @default(autoincrement())

  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  recipientName   String  @map("recipient_name")
  phoneNumber     String  @map("phone_number")
  shippingAddress String? @map("shipping_address") @db.Text

  deliveryOption String @map("delivery_option")
  shippingCost   Int    @map("shipping_cost")
  totalPrice     Int    @map("total_price")

  paymentMethod  String? @map("payment_method")
  paymentReceipt String? @map("payment_receipt")

  status String @default("menunggu pembayaran")

  pointsUsed    Int     @default(0) @map("points_used")
  pointsEarned  Int     @default(0) @map("points_earned")
  customerNotes String? @map("customer_notes") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items OrderItem[]

  @@map("orders")
}

model OrderItem {
  id Int @id @default(autoincrement())

  orderId Int   @map("order_id")
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId Int?     @map("product_id")
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  variantId Int?            @map("variant_id")
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  productName String  @map("product_name")
  variantName String? @map("variant_name")

  quantity Int
  price    Int

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("order_items")
}

model Message {
  id            Int      @id @default(autoincrement())
  userId        String   
  productId     Int?
  // Gunakan @map agar di kodingan kita panggil isFromAdmin, tapi di DB is_from_admin
  isFromAdmin   Boolean  @default(false) @map("is_from_admin") 
  sender        String   @default("user") 
  message       String   @db.Text
  isRead        Boolean  @default(false) @map("is_read")
  isEscalated   Boolean  @default(false) @map("is_escalated") // Ini kunci perbaikannya!
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  
  product       Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("messages")
}
